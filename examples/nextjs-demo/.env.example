# Copy to .env.local and fill in your sandbox credentials.
# Leave these UNSET to run the demo in mock mode (no network, no keys).

# Your sandbox API key id and HMAC secret (from the Payslice partner portal).
PAYSLICE_KEY_ID=
PAYSLICE_SECRET=

# Sandbox host. Do NOT include a /v1 suffix — the SDK adds it.
PAYSLICE_BASE_URL=https://sandbox-api.payslice.com

# Webhook signing secret (shown once when you register a webhook endpoint).
# Only needed if you point Payslice at /api/webhooks/payslice.
PAYSLICE_WEBHOOK_SECRET=

# The full URL you registered for webhooks, e.g.
# https://your-demo.vercel.app/api/webhooks/payslice — used to verify the
# signed path. Optional for a root-path receiver.
PAYSLICE_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Crypto custody payout page (/crypto). Leave UNSET to run that page in mock
# mode. This is the Vault/Rail service (Safe + Allowance Module + KMS delegate),
# a DIFFERENT service from the EWA API above — but the same HMAC signing.
# ---------------------------------------------------------------------------
# Vault/Rail base URL (host only — the route appends /v1/payout-authorizations).
# The rail's API is private; reach it with an SSH tunnel to the soak box:
#   ssh -i <key>.pem -L 8090:127.0.0.1:8090 ubuntu@<box-ip>
# then set:
VAULT_RAIL_BASE_URL=http://127.0.0.1:8090
# Inbound HMAC creds the rail accepts (its API_KEY_ID / API_HMAC_SECRET).
VAULT_RAIL_KEY_ID=
VAULT_RAIL_SECRET=
# Must match the rail's seeded company_payout_limits + EVM_NETWORK_ID.
VAULT_RAIL_PARTNER_ID=ptn_soak
VAULT_RAIL_NETWORK=base-sepolia
VAULT_RAIL_CURRENCY=USD
# The mock ERC-20 the rail settles in (from scripts/deploy-mock-tokens.sh) — also
# the contract the settlement scan watches. Required for live mode.
VAULT_RAIL_USD_TOKEN_CONTRACT=
VAULT_RAIL_TOKEN_DECIMALS=6
# Treasury Safe (display only) and the explorer for tx links.
VAULT_RAIL_SAFE_ADDRESS=
VAULT_RAIL_EXPLORER_BASE=https://sepolia.basescan.org
# Public Base Sepolia RPC used server-side to read the settlement transfer.
BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com
# Hard cap on a single payout (minor units / cents) — bounds the blast radius of
# the live money-moving endpoint. Default 100000 ($1,000).
VAULT_RAIL_MAX_AMOUNT_MINOR=100000
# SECURITY: the live payout route moves money and is DISABLED by default — it fails
# closed (`Host` is NOT trusted; it's spoofable). Enable it one of two ways:
#  - CRYPTO_DEMO_TOKEN=<secret>   real gate: callers must send `Authorization: Bearer <secret>`
#                                 (the browser page can't hold a secret, so this is for
#                                 programmatic callers / your own auth layer in front), OR
#  - VAULT_RAIL_ALLOW_REMOTE=1    run an intentionally-PUBLIC, cap-bounded demo (also the
#                                 switch to use live mode in local dev).
# CRYPTO_DEMO_TOKEN=
# VAULT_RAIL_ALLOW_REMOTE=1
