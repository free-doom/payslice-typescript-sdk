{
  "name": "@payslice/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Payslice Earned Wage Access (EWA) partner API.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "generate": "openapi-typescript ./openapi.yaml -o ./src/generated/types.ts",
    "generate:check": "openapi-typescript ./openapi.yaml -o ./src/generated/types.ts && git diff --exit-code -- ./src/generated/types.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "openapi-typescript": "^7.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "payslice",
    "ewa",
    "earned-wage-access",
    "sdk",
    "fintech"
  ]
}
